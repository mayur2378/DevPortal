{
  "name": "devportal",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=@devportal/db",
    "db:generate": "turbo run db:generate --filter=@devportal/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
